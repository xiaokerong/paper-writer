      align: [left, middle]
      text: |
        <p>🤖 已扩展，补充了2个案例与3组数据...</p>

  - elementId: multi-v-user2-bg
    elementType: shape
    bounds: [680, 460, 220, 36]
    shapeName: roundRect
    adjustments: [15000]
    fill: {type: solid, color: "$light"}

  - elementId: multi-v-user2-text
    elementType: text
    bounds: [690, 460, 200, 36]
    content:
      fontSize: 13
      color: "$text"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      text: |
        <p>👤 结论部分再精炼一下</p>

  - elementId: multi-v-ai2-bg
    elementType: shape
    bounds: [860, 505, 340, 50]
    shapeName: roundRect
    adjustments: [15000]
    fill: {type: solid, color: "#1B3A5F10"}

  - elementId: multi-v-ai2-text
    elementType: text
    bounds: [870, 505, 320, 50]
    content:
      fontSize: 13
      color: "$text"
      fontFamily: "QuattrocentoSans, MiSans"
      lineHeight: 1.4
      align: [left, middle]
      text: |
        <p>🤖 已精简，删除冗余表述，保留核心观点...</p>

  - elementId: multi-v-arrow1
    elementType: shape
    bounds: [790, 386, 0, 9]
    shapeName: straightConnector1
    arrow: [null, "arrow"]
    border: {style: dash, width: 1, color: "$secondary"}

  - elementId: multi-v-arrow2
    elementType: shape
    bounds: [790, 496, 0, 9]
    shapeName: straightConnector1
    arrow: [null, "arrow"]
    border: {style: dash, width: 1, color: "$secondary"}

  - elementId: page-num
    elementType: text
    bounds: [1180, 680, 60, 25]
    content:
      style: "$caption"
      align: [right, middle]
      wrap: false
      text: |
        <p>06</p>
