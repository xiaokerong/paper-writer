pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: nav-bg
    elementType: shape
    bounds: [0, 0, 1280, 40]
    shapeName: rect
    fill: {type: solid, color: "$primary"}

  - elementId: nav-ch1
    elementType: text
    bounds: [0, 0, 320, 40]
    content:
      fontSize: 14
      color: "#FFFFFF80"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p>01 项目背景与目标</p>

  - elementId: nav-ch2
    elementType: text
    bounds: [320, 0, 320, 40]
    content:
      fontSize: 14
      color: "$white"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p>02 系统架构与核心功能</p>

  - elementId: nav-ch3
    elementType: text
    bounds: [640, 0, 320, 40]
    content:
      fontSize: 14
      color: "#FFFFFF80"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p>03 技术亮点与实现</p>

  - elementId: nav-ch4
    elementType: text
    bounds: [960, 0, 320, 40]
    content:
      fontSize: 14
      color: "#FFFFFF80"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p>04 项目成果与展望</p>

  - elementId: nav-indicator
    elementType: shape
    bounds: [320, 40, 320, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 3, color: "$accent"}

  - elementId: page-title
    elementType: text
    bounds: [60, 55, 700, 42]
    content:
      style: "$heading"
      align: [left, middle]
      wrap: false
      text: |
        <p>核心功能：查重降重与可视化分析</p>

  - elementId: title-bar
    elementType: shape
    bounds: [60, 100, 50, 4]
    shapeName: rect
    fill: {type: solid, color: "$accent"}

  - elementId: plag-left-bg
    elementType: shape
    bounds: [60, 120, 570, 300]
    shapeName: roundRect
    adjustments: [6000]
    fill: {type: solid, color: "$light"}

  - elementId: plag-icon
    elementType: icon
    bounds: [85, 140, 28, 28]
    iconName: "fas:magnifying-glass-chart"
    fill: {type: solid, color: "$primary"}

  - elementId: plag-title
    elementType: text
    bounds: [125, 138, 250, 30]
    content:
      style: "$subheading"
      fontSize: 20
      align: [left, middle]
      wrap: false
      text: |
        <p>查重与降重</p>

  - elementId: plag-content
    elementType: text
    bounds: [85, 180, 520, 220]
    content:
      style: "$body"
      fontSize: 16
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p><strong>查重分析</strong></p>
        <p>• AI 评估文本原创性，识别潜在重复风险</p>
        <p>• 给出原创性评分与改进建议</p>
        <p> </p>
        <p><strong>智能降重</strong></p>
        <p>• 同义替换、句式重组、语序调整</p>
        <p>• 保持学术语义不变，降低相似度</p>

  - elementId: vis-right-bg
    elementType: shape
    bounds: [60, 440, 570, 260]
    shapeName: roundRect
    adjustments: [6000]
    fill: {type: solid, color: "$light"}

  - elementId: vis-icon
    elementType: icon
    bounds: [85, 460, 28, 28]
    iconName: "fas:chart-column"
    fill: {type: solid, color: "$accent"}

  - elementId: vis-title
    elementType: text
    bounds: [125, 458, 250, 30]
    content:
      style: "$subheading"
      fontSize: 20
      align: [left, middle]
      wrap: false
      text: |
        <p>学术配图生成</p>

  - elementId: vis-content
    elementType: text
    bounds: [85, 500, 520, 180]
    content:
      style: "$body"
      fontSize: 16
      lineHeight: 1.7
      align: [left, top]
      text: |
        <p>• AI 根据论文内容自动生成学术图表</p>
        <p>• 支持柱状图、折线图、饼图、散点图、流程图</p>
        <p>• 数据表格自动生成与格式化</p>
        <p>• 图表配色符合学术规范，可直接插入论文</p>

  - elementId: analysis-title
    elementType: text
    bounds: [660, 120, 300, 30]
    content:
      style: "$subheading"
      fontSize: 20
      align: [left, middle]
      wrap: false
      text: |
        <p>可视化分析能力</p>

  - elementId: analysis-list
    elementType: text
    bounds: [660, 165, 560, 235]
    content:
      style: "$body"
      fontSize: 16
      lineHeight: 1.8
      align: [left, top]
      text: |
        <p><strong>词云分析</strong> — 领域高频关键词可视化</p>
        <p><strong>引文分析</strong> — 高引论文排行与年份分布</p>
        <p><strong>关键词网络</strong> — 共现关联网络图</p>
        <p><strong>研究热点</strong> — 年度演化趋势追踪</p>
        <p><strong>选题趋势</strong> — 发文量年度趋势曲线</p>
        <p><strong>对比雷达</strong> — 多选题多维度对比</p>

  - elementId: chart-demo
    elementType: chart
    bounds: [660, 420, 560, 240]
    type: bar
    data:
      - {type: "词云", num: 1}
      - {type: "引文分析", num: 2}
      - {type: "关键词网络", num: 3}
      - {type: "研究热点", num: 4}
    x: type
    y: [num]
    names: ["可视化类型"]
    colors: ["$primary"]
    legend: false
    xAxis:
      label: {fontSize: 12}
    yAxis: {show: false}
    dataLabels:
      show: true
      content: value
      fontSize: 12
    options:
      fontFamily: "QuattrocentoSans, MiSans"

  - elementId: page-num
    elementType: text
    bounds: [1180, 680, 60, 25]
    content:
      style: "$caption"
      align: [right, middle]
      wrap: false
      text: |
        <p>09</p>
