pageType: table_of_contents
background:
  type: solid
  color: "$background"
elements:
  - elementId: toc-title
    elementType: text
    bounds: [60, 50, 300, 50]
    content:
      style: "$heading"
      fontSize: 36
      align: [left, middle]
      wrap: false
      text: |
        <p>目录</p>

  - elementId: toc-title-bar
    elementType: shape
    bounds: [60, 105, 60, 4]
    shapeName: rect
    fill: {type: solid, color: "$accent"}

  - elementId: toc-deco-text
    elementType: text
    bounds: [60, 140, 360, 500]
    content:
      fontSize: 120
      color: "#1B3A5F08"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, top]
      wrap: false
      text: |
        <p>CONT</p>
        <p>ENTS</p>

  - elementId: toc-card-bg-1
    elementType: shape
    bounds: [400, 140, 340, 240]
    shapeName: roundRect
    adjustments: [8000]
    fill: {type: solid, color: "$light"}

  - elementId: toc-num-1
    elementType: text
    bounds: [420, 160, 80, 50]
    content:
      fontSize: 36
      color: "$accent"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p>01</p>

  - elementId: toc-label-1
    elementType: text
    bounds: [420, 220, 300, 30]
    content:
      style: "$subheading"
      fontSize: 22
      align: [left, middle]
      wrap: false
      text: |
        <p>项目背景与目标</p>

  - elementId: toc-desc-1
    elementType: text
    bounds: [420, 260, 300, 35]
    content:
      style: "$body"
      fontSize: 16
      color: "$secondary"
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p>痛点分析、项目定位与核心目标</p>

  - elementId: toc-card-bg-2
    elementType: shape
    bounds: [780, 140, 440, 240]
    shapeName: roundRect
    adjustments: [8000]
    fill: {type: solid, color: "$light"}

  - elementId: toc-num-2
    elementType: text
    bounds: [800, 160, 80, 50]
    content:
      fontSize: 36
      color: "$accent"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p>02</p>

  - elementId: toc-label-2
    elementType: text
    bounds: [800, 220, 400, 30]
    content:
      style: "$subheading"
      fontSize: 22
      align: [left, middle]
      wrap: false
      text: |
        <p>系统架构与核心功能</p>

  - elementId: toc-desc-2
    elementType: text
    bounds: [800, 260, 400, 35]
    content:
      style: "$body"
      fontSize: 16
      color: "$secondary"
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p>前后端架构、论文生成、润色、排版、选题、可视化</p>

  - elementId: toc-card-bg-3
    elementType: shape
    bounds: [400, 410, 440, 240]
    shapeName: roundRect
    adjustments: [8000]
    fill: {type: solid, color: "$light"}

  - elementId: toc-num-3
    elementType: text
    bounds: [420, 430, 80, 50]
    content:
      fontSize: 36
      color: "$accent"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p>03</p>

  - elementId: toc-label-3
    elementType: text
    bounds: [420, 490, 400, 30]
    content:
      style: "$subheading"
      fontSize: 22
      align: [left, middle]
      wrap: false
      text: |
        <p>技术亮点与实现</p>

  - elementId: toc-desc-3
    elementType: text
    bounds: [420, 530, 400, 35]
    content:
      style: "$body"
      fontSize: 16
      color: "$secondary"
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p>Prompt工程、JSON容错、模块化引擎、模板体系</p>

  - elementId: toc-card-bg-4
    elementType: shape
    bounds: [880, 410, 340, 240]
    shapeName: roundRect
    adjustments: [8000]
    fill: {type: solid, color: "$light"}

  - elementId: toc-num-4
    elementType: text
    bounds: [900, 430, 80, 50]
    content:
      fontSize: 36
      color: "$accent"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p>04</p>

  - elementId: toc-label-4
    elementType: text
    bounds: [900, 490, 300, 30]
    content:
      style: "$subheading"
      fontSize: 22
      align: [left, middle]
      wrap: false
      text: |
        <p>项目成果与展望</p>

  - elementId: toc-desc-4
    elementType: text
    bounds: [900, 530, 300, 35]
    content:
      style: "$body"
      fontSize: 16
      color: "$secondary"
      lineHeight: 1.5
      align: [left, top]
      text: |
        <p>成果总结、API概览、未来方向</p>
