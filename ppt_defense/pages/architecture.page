    bounds: [392, 218, 190, 30]
    content:
      fontSize: 16
      color: "$primary"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>后端服务</strong></p>

  - elementId: be-desc
    elementType: text
