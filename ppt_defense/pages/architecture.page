      fontSize: 14
      color: "$secondary"
      fontFamily: "QuattrocentoSans, MiSans"
      lineHeight: 1.4
      align: [left, top]
      text: |
        <p>DeepSeek v4 API</p>
        <p>结构化 Prompt 工程</p>

  - elementId: polish-card-bg
    elementType: shape
    bounds: [340, 325, 260, 110]
