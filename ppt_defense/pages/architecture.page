pageType: content
background:
  type: solid
  color: "$background"
elements:
  - elementId: nav-bg
    elementType: shape
    bounds: [0, 0, 1280, 40]
    shapeName: rect
    fill: {type: solid, color: "$primary"}

  - elementId: nav-ch1
    elementType: text
    bounds: [0, 0, 320, 40]
    content:
      fontSize: 14
      color: "#FFFFFF80"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p>01 项目背景与目标</p>

  - elementId: nav-ch2
    elementType: text
    bounds: [320, 0, 320, 40]
    content:
      fontSize: 14
      color: "$white"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p>02 系统架构与核心功能</p>

  - elementId: nav-ch3
    elementType: text
    bounds: [640, 0, 320, 40]
    content:
      fontSize: 14
      color: "#FFFFFF80"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p>03 技术亮点与实现</p>

  - elementId: nav-ch4
    elementType: text
    bounds: [960, 0, 320, 40]
    content:
      fontSize: 14
      color: "#FFFFFF80"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [center, middle]
      wrap: false
      text: |
        <p>04 项目成果与展望</p>

  - elementId: nav-indicator
    elementType: shape
    bounds: [320, 40, 320, 0]
    shapeName: straightConnector1
    border: {style: solid, width: 3, color: "$accent"}

  - elementId: page-title
    elementType: text
    bounds: [60, 55, 500, 42]
    content:
      style: "$heading"
      align: [left, middle]
      wrap: false
      text: |
        <p>系统架构总览</p>

  - elementId: title-bar
    elementType: shape
    bounds: [60, 100, 50, 4]
    shapeName: rect
    fill: {type: solid, color: "$accent"}

  - elementId: arch-desc
    elementType: text
    bounds: [60, 120, 550, 70]
    content:
      style: "$body"
      fontSize: 18
      lineHeight: 1.6
      align: [left, top]
      text: |
        <p>前后端分离架构，模块化引擎设计，</p>
        <p>覆盖论文写作全流程服务。</p>

  - elementId: fe-card-bg
    elementType: shape
    bounds: [60, 205, 260, 110]
    shapeName: roundRect
    adjustments: [8000]
    fill: {type: solid, color: "$white"}
    border: {style: solid, width: 1, color: "$divider"}

  - elementId: fe-icon
    elementType: icon
    bounds: [75, 220, 28, 28]
    iconName: "fas:desktop"
    fill: {type: solid, color: "$primary"}

  - elementId: fe-title
    elementType: text
    bounds: [112, 218, 190, 30]
    content:
      fontSize: 16
      color: "$primary"
      fontFamily: "QuattrocentoSans, MiSans"
      align: [left, middle]
      wrap: false
      text: |
        <p><strong>前端层</strong></p>

  - elementId: fe-desc
    elementType: text
    bounds: [75, 255, 230, 55]
    content:
      fontSize: 14
      color: "$secondary"
      fontFamily: "QuattrocentoSans, MiSans"
      lineHeight: 1.4
      align: [left, top]
      text: |
        <p>React + TypeScript</p>
        <p>Tailwind CSS + Vite</p>

  - elementId: be-card-bg
    elementType: shape
    bounds: [340, 205, 260, 110]
